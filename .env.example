DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="fallback_secret_for_local_dev"

# Required for production: set to your actual domain (e.g. https://badges.example.com)
# If not set, NextAuth defaults to http://localhost:3000
NEXTAUTH_URL=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_APP_NAME="OtterBadges"

# Set to "true" to disable new user signups via email/password
NEXT_PUBLIC_DISABLE_SIGNUP="false"

# Set to "true" to disable email/password login entirely (useful if you only want Google OAuth)
NEXT_PUBLIC_DISABLE_LOCAL_LOGIN="false"

# Set to "true" to automatically redirect users to Google SSO when they land on the login page
NEXT_PUBLIC_AUTO_SSO="false"